  "dependencies": {
    "@x402/evm": "^2.11.0",
    "@x402/fetch": "^2.11.0",
    "viem": "^2.39.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
